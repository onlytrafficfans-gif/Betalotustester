# LOTUS App Builder — Environment Variables
# Copy this file to .env and fill in your API keys

# Groq API Key (recommended — fast, cheap, good for structured output)
VITE_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: OpenAI API Key
# VITE_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Default AI provider (groq | openai | mock)
VITE_AI_PROVIDER=groq

# Optional: Default model per provider
VITE_GROQ_MODEL=llama-3.3-70b-versatile
# VITE_OPENAI_MODEL=gpt-4o-mini
